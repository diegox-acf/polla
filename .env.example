# Copia este archivo a .env y completa los valores. .env está gitignoreado.

# Postgres — local: docker compose up -d | producción: connection string de Neon
DATABASE_URL=postgresql://polla:polla@localhost:5432/polla

# Auth.js — generar con: npx auth secret
AUTH_SECRET=

# Google OAuth — Google Cloud Console > APIs & Services > Credentials > OAuth client ID (tipo: Web application)
# Authorized redirect URI (local): http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (prod):  https://<tu-dominio>.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# football-data.org — token gratis registrándote en https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# Email del admin de la polla — npm run db:seed lo agrega al allowlist con rol admin
ADMIN_EMAIL=
